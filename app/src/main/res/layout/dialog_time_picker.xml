<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/background_dark">

    <TextView
        android:id="@+id/text_picker_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Set wake time"
        android:textColor="@color/accent_gold"
        android:textSize="16sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:orientation="horizontal"
        android:gravity="center">

        <com.shawnlin.numberpicker.NumberPicker
            android:id="@+id/hourPicker"
            android:layout_width="80dp"
            android:layout_height="match_parent"
            app:np_min="1"
            app:np_max="12"
            app:np_selectedTextColor="@color/primary_lavender"
            app:np_textColor="@color/text_secondary"
            app:np_textSize="24sp"
            app:np_selectedTextSize="42sp"
            app:np_wheelItemCount="5"
            app:np_dividerColor="@android:color/transparent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textColor="@color/primary_lavender"
            android:textSize="30sp"
            android:textStyle="bold"
            android:paddingHorizontal="8dp" />

        <com.shawnlin.numberpicker.NumberPicker
            android:id="@+id/minutePicker"
            android:layout_width="80dp"
            android:layout_height="match_parent"
            app:np_min="0"
            app:np_max="59"
            app:np_selectedTextColor="@color/primary_lavender"
            app:np_textColor="@color/text_secondary"
            app:np_textSize="24sp"
            app:np_selectedTextSize="42sp"
            app:np_wheelItemCount="5"
            app:np_dividerColor="@android:color/transparent" />

        <com.shawnlin.numberpicker.NumberPicker
            android:id="@+id/ampmPicker"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            app:np_selectedTextColor="@color/primary_lavender"
            app:np_textColor="@color/text_secondary"
            app:np_textSize="18sp"
            app:np_selectedTextSize="22sp"
            app:np_wheelItemCount="5"
            app:np_dividerColor="@android:color/transparent" />
    </LinearLayout>

</LinearLayout>