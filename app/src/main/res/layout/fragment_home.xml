<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:id="@+id/text_duration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Duration: --"
        android:textSize="16sp"
        android:paddingBottom="8dp" />
    <TextView
        android:id="@+id/text_current_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Current time: --"
        android:textSize="16sp"
        android:paddingBottom="8dp"/>

    <TextView
        android:id="@+id/text_alarm_triggered_at"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Alarm triggered at: --"
        android:textSize="16sp"
        android:paddingBottom="16dp"/>

    <TextView
        android:id="@+id/text_bpm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BPM: --"
        android:textSize="20sp"
        android:paddingBottom="8dp"/>

    <TextView
        android:id="@+id/text_phase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Phase: --"
        android:textSize="20sp"
        android:paddingBottom="8dp"/>

    <TextView
        android:id="@+id/text_alarm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Alarm: OFF"
        android:textSize="20sp"
        android:paddingBottom="16dp"/>

    <TextView
        android:id="@+id/text_alarm_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Alarm not configured"
        android:textSize="16sp"
        android:paddingBottom="20dp"/>

    <Button
        android:id="@+id/button_set_alarm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set Alarm"/>

    <Button
        android:id="@+id/button_set_window"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set Smart Window"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/button_start"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start"
        android:layout_marginTop="20dp"/>

    <com.example.smartalarm.ui.view.SleepChartView
        android:id="@+id/sleep_chart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp" />

</LinearLayout>